# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Mot de passe Postgres (Settings → Database) — pour `supabase link` / migrations CLI
SUPABASE_DB_PASSWORD=

# Google OAuth (dev local avec supabase start)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push (npm run gen:vapid)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:deepna@app.com

# Cron push reminders (GET /api/cron/push-reminders)
CRON_SECRET=

# Stripe (optionnel)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
